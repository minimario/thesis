@misc{borg2024-ghost-echoes,
  author   = {Markus Borg and Marwa Ezzouhri and Adam Tornhill},
  title    = {Ghost Echoes Revealed: Benchmarking Maintainability Metrics and Machine Learning Predictions Against Human Assessments},
  year     = {2024},
  doi      = {10.48550/arXiv.2408.10754},
  abstract = {As generative AI is expected to increase global code volumes, the importance of maintainability from a human perspective will become even greater. This study benchmarks several maintainability prediction approaches, including SotA ML, SonarQube, CodeScene's Code Health, and Microsoft's Maintainability Index. Results indicate that CodeScene matches the accuracy of SotA ML and outperforms the average human expert.}
}

@inproceedings{borg2024-maintainable-code,
  author    = {Markus Borg and Ilyana Pruvost and Enys Mones and Adam Tornhill},
  title     = {Increasing, not Diminishing: Investigating the Returns of Highly Maintainable Code},
  booktitle = {Proceedings of the 7th ACM/IEEE International Conference on Technical Debt},
  pages     = {21--30},
  publisher = {ACM},
  year      = {2024},
  doi       = {10.1145/3644384.3644471},
  abstract  = {We combine two publicly available datasets to study the association between code quality and defect count and implementation time. Our value model suggests strong non-linearities at the extremes of the code quality spectrum, with amplified returns on investment in the upper end. We discuss the findings within the context of the ``broken windows'' theory.}
}

@misc{borg2026-code-for-machines,
  author   = {Markus Borg and Nadim Hagatulah and Adam Tornhill and Emma S\"{o}derberg},
  title    = {Code for Machines, Not Just Humans: Quantifying {AI}-Friendliness with Code Health Metrics},
  year     = {2026},
  doi      = {10.48550/arXiv.2601.02200},
  url      = {https://arxiv.org/abs/2601.02200},
  abstract = {We investigate the concept of ``AI-friendly code'' via LLM-based refactoring on a dataset of 5,000 Python files. We find a meaningful association between CodeHealth, a quality metric calibrated for human comprehension, and semantic preservation after AI refactoring. Our findings confirm that human-friendly code is also more compatible with AI tooling.}
}

@misc{sepidband2025-complexity-feedback,
  author   = {Melika Sepidband and Hamed Taherkhani and Song Wang and Hadi Hemmati},
  title    = {Enhancing {LLM}-Based Code Generation with Complexity Metrics: A Feedback-Driven Approach},
  year     = {2025},
  doi      = {10.48550/arXiv.2505.23953},
  abstract = {We investigate the relationship between code complexity and the success of LLM-generated code. Using logistic regression models, we identify which complexity metrics are most predictive of code correctness. We propose an iterative feedback method where LLMs are prompted to generate correct code based on complexity metrics from previous failed outputs, achieving notable improvements.}
}

@misc{abdelsalam2025-confusing-code,
  author   = {Youssef Abdelsalam and Norman Peitek and Anna-Maria Maurer and Mariya Toneva and Sven Apel},
  title    = {How do Humans and {LLMs} Process Confusing Code?},
  year     = {2025},
  doi      = {10.48550/ARXIV.2508.18547},
  abstract = {We conducted an empirical study comparing an LLM to human programmers comprehending clean and confusing code. We operationalized comprehension for the LLM by using LLM perplexity, and for human programmers using neurophysiological responses. We found that LLM perplexity spikes correlate both in terms of location and amplitude with human neurophysiological responses that indicate confusion.}
}
