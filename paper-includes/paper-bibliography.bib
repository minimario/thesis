@misc{borg2026-code-for-machines,
  author   = {Markus Borg and Nadim Hagatulah and Adam Tornhill and Emma S\"{o}derberg},
  title    = {Code for Machines, Not Just Humans: Quantifying {AI}-Friendliness with Code Health Metrics},
  year     = {2026},
  doi      = {10.48550/arXiv.2601.02200},
  url      = {https://arxiv.org/abs/2601.02200},
  abstract = {We investigate the concept of ``AI-friendly code'' via LLM-based refactoring on a dataset of 5,000 Python files. We find a meaningful association between CodeHealth, a quality metric calibrated for human comprehension, and semantic preservation after AI refactoring. Our findings confirm that human-friendly code is also more compatible with AI tooling.}
}

