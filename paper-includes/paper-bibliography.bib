@misc{sepidband2025-complexity-feedback,
  author   = {Melika Sepidband and Hamed Taherkhani and Song Wang and Hadi Hemmati},
  title    = {Enhancing {LLM}-Based Code Generation with Complexity Metrics: A Feedback-Driven Approach},
  year     = {2025},
  doi      = {10.48550/arXiv.2505.23953},
  abstract = {We investigate the relationship between code complexity and the success of LLM-generated code. Using logistic regression models, we identify which complexity metrics are most predictive of code correctness. We propose an iterative feedback method where LLMs are prompted to generate correct code based on complexity metrics from previous failed outputs, achieving notable improvements.}
}

