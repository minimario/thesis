@misc{nakashima2026-agentic-prs,
  author   = {Sota Nakashima and Yuta Ishimoto and Masanari Kondo and Shane McIntosh and Yasutaka Kamei},
  title    = {Why Agentic-{PRs} Get Rejected: A Comparative Study of Coding Agents},
  year     = {2026},
  doi      = {10.48550/arXiv.2602.04226},
  abstract = {Agentic coding is rapidly gaining traction. Prior work has shown that Pull Requests produced using coding agents are accepted less often than human PRs. We inspect 654 rejected PRs from the AIDev dataset covering five coding agents. Our results show that seven rejection modes occur only in Agentic-PRs, including distrust of AI-generated code.}
